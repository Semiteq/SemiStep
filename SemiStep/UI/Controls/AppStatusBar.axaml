<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="UI.Controls.AppStatusBar">

    <Border Name="StatusBarBorder"
            Background="#F0F0F0"
            BorderBrush="#D0D0D0"
            BorderThickness="0,1,0,0"
            Padding="8,4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Status Text (Modified/Saved) -->
            <TextBlock Grid.Column="0"
                       Name="StatusText"
                       Text="{Binding StatusText}"
                       VerticalAlignment="Center"
                       FontSize="12" />

            <!-- Separator -->
            <Border Grid.Column="1"
                    Width="1"
                    Background="#C0C0C0"
                    Margin="12,2" />

            <!-- Error/Warning counts - clickable to toggle log panel -->
            <Button Grid.Column="2"
                    Command="{Binding ToggleLogPanelCommand}"
                    IsVisible="{Binding HasStatusErrors}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,2"
                    VerticalAlignment="Center"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <!-- Error count -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                IsVisible="{Binding HasErrors}">
                        <Ellipse Width="8" Height="8"
                                 Fill="#D32F2F"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ErrorCountText}"
                                   FontSize="12"
                                   Foreground="#D32F2F"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Warning count -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="4"
                                IsVisible="{Binding HasWarnings}">
                        <Ellipse Width="8" Height="8"
                                 Fill="#F57C00"
                                 VerticalAlignment="Center" />
                        <TextBlock Text="{Binding WarningCountText}"
                                   FontSize="12"
                                   Foreground="#F57C00"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Button>

            <!-- Separator (only if errors visible) -->
            <Border Grid.Column="3"
                    Width="1"
                    Background="#C0C0C0"
                    Margin="12,2"
                    IsVisible="{Binding HasStatusErrors}" />

            <!-- Spacer -->
            <Panel Grid.Column="4" />

            <!-- Connection Status -->
            <StackPanel Grid.Column="5"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Ellipse Width="8"
                         Height="8"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center">
                    <Ellipse.Styles>
                        <Style Selector="Ellipse">
                            <Setter Property="Fill" Value="#FF4444" />
                        </Style>
                    </Ellipse.Styles>
                </Ellipse>
                <TextBlock Name="ConnectionText"
                           Text="{Binding ConnectionStatus}"
                           VerticalAlignment="Center"
                           FontSize="12" />
            </StackPanel>
        </Grid>
    </Border>

</UserControl>
